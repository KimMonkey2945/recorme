# 릴리즈 서명 키 설정 템플릿.
#
# 사용법:
#   1) 릴리즈 키스토어 생성(한 번만, 안전하게 백업할 것 — 분실 시 같은 키로 업데이트 불가):
#        keytool -genkey -v -keystore recorme-release.jks \
#          -keyalg RSA -keysize 2048 -validity 10000 -alias recorme
#   2) 이 파일을 android/key.properties 로 복사하고 값 채우기(key.properties 는 gitignore 됨).
#   3) ⚠️ storeFile 상대경로는 Gradle :app 모듈 기준, 즉 android/app/ 기준으로 해석된다
#      (key.properties 위치인 android/ 기준이 아님). 혼동을 피하려면 절대경로 권장.
#      docs/deployment.md Phase 8 은 android/app/ 에서 keytool 을 실행하므로 storeFile=recorme-release.jks 로 일치.
#
# ⚠️ key.properties 와 *.jks 는 절대 커밋 금지. debug 키로 배포하면 기기·머신마다 키가 달라
#    "덮어 설치 업데이트"가 서명 불일치로 실패한다.

storePassword=여기에_키스토어_비밀번호
keyPassword=여기에_키_비밀번호
keyAlias=recorme
storeFile=recorme-release.jks
