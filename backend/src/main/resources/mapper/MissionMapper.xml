<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.recordapp.domain.character.mapper.MissionMapper">

    <resultMap id="missionRowMap" type="com.recordapp.domain.character.dto.MissionRow">
        <constructor>
            <idArg column="code" javaType="java.lang.String"/>
            <arg column="title" javaType="java.lang.String"/>
            <arg column="description" javaType="java.lang.String"/>
            <arg column="rule_type" javaType="com.recordapp.domain.character.vo.MissionRuleType"/>
            <arg column="threshold" javaType="_int"/>
            <arg column="coin_reward" javaType="_int"/>
            <arg column="item_group_reward" javaType="java.lang.String"/>
        </constructor>
    </resultMap>

    <resultMap id="userMissionRowMap" type="com.recordapp.domain.character.dto.UserMissionRow">
        <constructor>
            <idArg column="mission_code" javaType="java.lang.String"/>
            <arg column="achieved_at" javaType="java.time.OffsetDateTime"/>
        </constructor>
    </resultMap>

    <!-- 활성 미션(idx_missions_active 부분 인덱스와 동일 조건·정렬).
         rule(JSONB)의 임계값 키는 타입마다 다르다: DIARY_COUNT=count / CONSECUTIVE_DAYS=days /
         RESOLUTION_SUCCESS=count / RESOLUTION_STREAK=seq / LEVEL=level.
         COALESCE 로 threshold 하나로 정규화해 읽어, 서비스·앱이 타입별 키를 알 필요가 없게 한다
         (chk_missions_rule_type 이 타입 오타를 막으므로 COALESCE 가 NULL 로 떨어지는 일은 없다). -->
    <select id="findMissions" resultMap="missionRowMap">
        SELECT code,
               title,
               description,
               rule ->> 'type' AS rule_type,
               COALESCE(rule ->> 'count',
                        rule ->> 'days',
                        rule ->> 'seq',
                        rule ->> 'level')::int AS threshold,
               coin_reward,
               item_group_reward
          FROM missions
         WHERE active
         ORDER BY sort_order, code
    </select>

    <!-- 내 달성 이력((user_id, mission_code) PK 스캔). -->
    <select id="findAchievedMissions" resultMap="userMissionRowMap">
        SELECT mission_code,
               achieved_at
          FROM user_missions
         WHERE user_id = #{userId}
    </select>

</mapper>
