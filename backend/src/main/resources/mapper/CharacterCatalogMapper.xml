<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.recordapp.domain.character.mapper.CharacterCatalogMapper">

    <!-- ⚠️ constructor 매핑이라 <arg> 순서가 record 표준 생성자 인자 순서와 정확히 일치해야 한다
         (map-underscore-to-camel-case 는 constructor <arg> 에 auto-apply 되지 않는다 — ResolutionMapper 관례). -->
    <resultMap id="characterRowMap" type="com.recordapp.domain.character.dto.CharacterRow">
        <constructor>
            <idArg column="code" javaType="java.lang.String"/>
            <arg column="name_ko" javaType="java.lang.String"/>
            <arg column="tagline" javaType="java.lang.String"/>
            <arg column="rive_artboard" javaType="java.lang.String"/>
            <arg column="thumbnail_url" javaType="java.lang.String"/>
        </constructor>
    </resultMap>

    <!-- slot/acquire_type 은 VARCHAR CHECK 컬럼 → enum 으로 매핑(MyBatis 기본 EnumTypeHandler, name 기준). -->
    <resultMap id="itemGroupRowMap" type="com.recordapp.domain.character.dto.ItemGroupRow">
        <constructor>
            <idArg column="code" javaType="java.lang.String"/>
            <arg column="slot" javaType="com.recordapp.domain.character.vo.ItemSlot"/>
            <arg column="name_ko" javaType="java.lang.String"/>
            <arg column="thumbnail_url" javaType="java.lang.String"/>
            <arg column="acquire_type" javaType="com.recordapp.domain.character.vo.AcquireType"/>
            <arg column="coin_price" javaType="_int"/>
            <arg column="sort_order" javaType="_int"/>
        </constructor>
    </resultMap>

    <!-- render_meta(JSONB)는 ::text 로 원문을 읽어 캐시 적재 시 1회만 JsonNode 로 파싱한다
         (EmotionAnalysisMapper 가 emotion_scores 를 문자열로 다루는 것과 동일 전략 — 전용 TypeHandler 불필요). -->
    <resultMap id="characterItemRowMap" type="com.recordapp.domain.character.dto.CharacterItemRow">
        <constructor>
            <arg column="group_code" javaType="java.lang.String"/>
            <arg column="character_code" javaType="java.lang.String"/>
            <arg column="image_url" javaType="java.lang.String"/>
            <arg column="rive_slot" javaType="java.lang.String"/>
            <arg column="render_meta" javaType="java.lang.String"/>
        </constructor>
    </resultMap>

    <!-- 활성 캐릭터(온보딩 목록). 비활성 캐릭터는 신규 선택 대상이 아니다. -->
    <select id="findCharacters" resultMap="characterRowMap">
        SELECT code,
               name_ko,
               tagline,
               rive_artboard,
               thumbnail_url
          FROM characters
         WHERE active
         ORDER BY sort_order, code
    </select>

    <!-- 활성 아이템 그룹(옷장·상점 목록). idx_item_groups_slot(부분 인덱스)과 동일 조건·정렬. -->
    <select id="findItemGroups" resultMap="itemGroupRowMap">
        SELECT code,
               slot,
               name_ko,
               thumbnail_url,
               acquire_type,
               coin_price,
               sort_order
          FROM item_groups
         WHERE active
         ORDER BY slot, sort_order, code
    </select>

    <!-- 렌더 variant 전체(캐릭터 전용 + 공용). 캐시가 (group_code, character_code) 로 색인한다. -->
    <select id="findCharacterItems" resultMap="characterItemRowMap">
        SELECT group_code,
               character_code,
               image_url,
               rive_slot,
               render_meta::text AS render_meta
          FROM character_items
    </select>

</mapper>
