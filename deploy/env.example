# =============================================================================
# recorme 배포 환경변수 템플릿
#
# 사용법(서버에서):
#   cp deploy/env.example deploy/.env   # 이 파일을 복사해 실제 값을 채운다
#   # deploy/.env 는 .gitignore 로 제외됨(절대 커밋 금지)
#
# 파일명이 "env.example"인 이유: .gitignore 의 `.env.*` 규칙이 `.env.example` 을
# 무시하기 때문에 점 없는 이름으로 커밋한다.
# =============================================================================

# ----- PostgreSQL (단일 진실원) -----
# 아래 POSTGRES_* 만 채우면 백엔드 DB_USER/DB_PASSWORD 는 compose 폴백으로 자동 재사용된다
# (docker-compose.yml: DB_USER=${DB_USER:-${POSTGRES_USER}}, DB_PASSWORD=${DB_PASSWORD:-${POSTGRES_PASSWORD}}).
# 굳이 DB_USER/DB_PASSWORD 를 따로 쓰려면 반드시 POSTGRES_* 와 값을 일치시킬 것(불일치 시 인증 실패).
POSTGRES_DB=recorme
POSTGRES_USER=recorme
POSTGRES_PASSWORD=change-me-strong-password

# ----- 백엔드 데이터소스 (application-cloud.yml 이 읽는 실제 var 이름) -----
# ⚠️ SPRING_DATASOURCE_* 아님. DB_URL 의 DB 이름(/recorme)은 POSTGRES_DB 와 일치해야 함(host=compose 서비스명 db).
DB_URL=jdbc:postgresql://db:5432/recorme
# DB_USER / DB_PASSWORD 는 미설정 시 POSTGRES_* 로 자동 폴백(위 안내). 필요할 때만 주석 해제·값 일치.
# DB_USER=recorme
# DB_PASSWORD=change-me-strong-password
# (선택) 커넥션 풀 크기
# DB_POOL_SIZE=10

# ----- Supabase Auth (ES256/JWKS 검증 전용) — 필수 -----
# 앱의 supabase_config.dart 와 동일 프로젝트를 가리켜야 함.
SUPABASE_URL=https://<your-project-ref>.supabase.co

# ----- 감정 분석 LLM (기본 Gemini) -----
# 키가 비면 Stub 로 폴백(실제 분석 없음). Gemini 무료 등급 권장 모델: gemini-2.5-flash-lite.
LLM_PROVIDER=gemini
LLM_API_KEY=<gemini-api-key>
LLM_MODEL=gemini-2.5-flash-lite
# 로컬 LLM 실험 시:
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://ollama:11434

# ----- FCM 푸시 (작심삼일 리마인더/완주) -----
# 권장: 서비스계정 JSON 을 Base64 로 인코딩해 한 줄로 주입(파일 마운트 불필요 → Jenkins 자동배포 안전).
#   Linux:   base64 -w0 fcm.json
#   결과 문자열을 아래에 붙여넣는다.
# 비우면 StubPushService 로 폴백(실제 발송 없음).
FCM_CREDENTIALS=
# (대안) 파일 경로 방식: compose 의 secrets 마운트 주석 해제 후 아래처럼 지정.
# FCM_CREDENTIALS=/secrets/fcm.json

# ----- (참고) 스토리지 -----
# STORAGE_ROOT 는 compose 에서 /app/var/storage 로 고정 주입하므로 여기서 설정 불필요.
