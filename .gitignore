# ===== 공통 =====
*.log
*.class
.DS_Store

# ===== IDE =====
.idea/
*.iml
*.ipr
*.iws
.vscode/

# ===== Flutter (app/) =====
# 상세 규칙은 app/.gitignore 참고
app/.dart_tool/
app/build/
app/.flutter-plugins-dependencies
app/.pub-cache/
app/.pub/

# ===== Spring Boot / Gradle (backend/) =====
backend/.gradle/
backend/build/
backend/out/
backend/bin/
!backend/gradle/wrapper/gradle-wrapper.jar

# ===== 환경/시크릿 =====
*.env
.env.*
application-local.yml
application-secret.yml

# ===== 배포(deploy/) — 실제 시크릿·런타임 데이터 (env.example 만 커밋) =====
deploy/.env
deploy/secrets/
deploy/data/

# ===== Android 릴리즈 서명 (절대 커밋 금지, key.properties.example 만 커밋) =====
app/android/key.properties
**/*.jks
**/*.keystore

